<!DOCTYPE html>
<html>
<head>
    <title>Queen's RPS Game 👑</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
   
</head>
<body>
    <h1><b>Rock Paper Scissors Game</b></h1>
    <p>Queen's First Game 🎮</p>
    <div id="scoreboard">
        <b>Scoreboard 👑</b><br>
        Wins: <span id="wins">0</span> | 
        Losses: <span id="losses">0</span> | 
        Ties: <span id="ties">0</span>
    </div>

    <button onclick="playGame('Rock')">Rock 🪨</button>
    <button onclick="playGame('Paper')">Paper 📄</button>
    <button onclick="playGame('Scissors')">Scissors ✂️</button>
    <div id="result">Chal Queen, move khel! 🏁</div>
    
    <button class="reset-btn" onclick="resetScore()">Reset Score 🔄</button>
    
    <p><a href="../">← Back to GT650 Garage</a></p>

    <script>
        let score = {
            wins: 0,
            losses: 0,
            ties: 0
        };
        function playGame(playerMove) {
            const randomNumber = Math.random();
            let computerMove = '';
            
            if(randomNumber < 1/3) {
                computerMove = 'Rock';
            } else if(randomNumber < 2/3) {
                computerMove = 'Paper';
            } else {
                computerMove = 'Scissors';
            }
            
             let result = '';
            let resultClass = '';
            
            if(playerMove === computerMove) {
                result = 'Tie';
                score.ties++;
                resultClass = 'tie';
            } else if(
                (playerMove === 'Rock' && computerMove === 'Scissors') ||
                (playerMove === 'Paper' && computerMove === 'Rock') ||
                (playerMove === 'Scissors' && computerMove === 'Paper')
            ) {
                result = 'You Win! 👑';
                score.wins++;
                resultClass = 'win';
            } else {
                result = 'You Lose';
                score.losses++;
                resultClass = 'lose';
            }
            
            // Scoreboard update karo
            updateScoreboard();
            
            // Result page pe dikhao, alert nahi
            document.getElementById('result').innerHTML = 
                `Tu: ${playerMove} | Bot: ${computerMove} <br>
                 <span class="${resultClass}">${result}</span>`;
        }
        
        function updateScoreboard() {
            document.getElementById('wins').textContent = score.wins;
            document.getElementById('losses').textContent = score.losses;
            document.getElementById('ties').textContent = score.ties;
        }
        
        function resetScore() {
            score.wins = 0;
            score.losses = 0;
            score.ties = 0;
            updateScoreboard();
            document.getElementById('result').innerHTML = 'Score reset! Phir se race shuru 🏍️💨';
        }
    </script>
</body>
</html>
